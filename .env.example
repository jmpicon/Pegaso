# ════════════════════════════════════════════════════════════════
# PEGASO — Configuración completa
# Copia a .env y ajusta los valores
# ════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga
LOG_LEVEL=INFO
ALLOWLIST_PATH=/app/data/vault

# ── Usuario ──────────────────────────────────────────────────────
# Nombre del usuario para personalización de Pegaso
PEGASO_USER=José

# ── LLM — Ferrumox Fox ───────────────────────────────────────────
# Motor Rust de alta performance: continuous batching,
# PagedAttention, prefix caching, flash attention
#
# Modelos GGUF recomendados (descargar en ./models/):
#   Calidad máxima:  Llama-3.1-8B-Instruct.Q6_K.gguf (~6GB VRAM)
#   Equilibrio:      Llama-3.2-3B-Instruct.Q8_0.gguf (~3.5GB VRAM)
#   Velocidad:       Qwen2.5-1.5B-Instruct.Q8_0.gguf (~2GB VRAM)
#
LLM_MODEL=llama-3.2-3b-instruct
VLLM_API_BASE=http://fox:8080/v1
OPENAI_API_KEY=local-pegaso

# ── Fox — Rendimiento máximo ──────────────────────────────────────
FOX_MODEL_PATH=/models/llama-3.2-3b-instruct.Q8_0.gguf
FOX_MAX_CONTEXT_LEN=16384
FOX_GPU_MEMORY_FRACTION=0.92
FOX_MAX_BATCH_SIZE=64
FOX_NUM_THREADS=8
FOX_ROPE_SCALING=1.0
FOX_FLASH_ATTN=1
FOX_LOG_LEVEL=info
RUST_LOG=ferrumox=info

# ── Base de datos PostgreSQL ──────────────────────────────────────
POSTGRES_USER=pegaso
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_DB=pegaso_db
DATABASE_URL=postgresql://pegaso:cambia-esto-en-produccion@db/pegaso_db

# ── Vector DB Qdrant ──────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Redis & Worker ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Búsqueda privada SearXNG ──────────────────────────────────────
SEARXNG_URL=http://searxng:8080

# ── Aprendizaje adaptativo ────────────────────────────────────────
LEARNING_DIR=/app/data/vault/learning

# ── Opcional: Perplexity CLI (agente externo) ─────────────────────
# PERPLEXITY_API_KEY=tu-api-key-aqui
# PERPLEXITY_MODEL=sonar-pro
