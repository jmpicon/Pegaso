# PEGASO CORE
APP_ENV=development
SECRET_KEY=4629007f9c8f1e63e9f4a9b5c2a1e8f3  # Example key
ALLOWLIST_PATH=/app/data/vault
LOG_LEVEL=INFO

# LLM — Ferrumox Fox (motor Rust de alta performance: continuous batching, PagedAttention, prefix caching)
# 1. Descarga un modelo GGUF en ./models/ (ej: llama-3.2-3b-instruct.Q8_0.gguf)
# 2. Ajusta FOX_MODEL_PATH con el nombre del fichero
# Modelos recomendados GGUF: Llama-3.2-3B-Instruct · Mistral-7B-Instruct · Qwen2.5-7B-Instruct
LLM_MODEL=llama-3.2-3b-instruct
VLLM_API_BASE=http://fox:8080/v1
OPENAI_API_KEY=local-pegaso

# Fox — Ajuste de rendimiento máximo
FOX_MODEL_PATH=/models/llama-3.2-3b-instruct.Q8_0.gguf
FOX_MAX_CONTEXT_LEN=8192
FOX_GPU_MEMORY_FRACTION=0.90
FOX_MAX_BATCH_SIZE=32

# DB
POSTGRES_USER=pegaso
POSTGRES_PASSWORD=pegaso_pass
POSTGRES_DB=pegaso_db
DATABASE_URL=postgresql://pegaso:pegaso_pass@db/pegaso_db

# VECTOR DB
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# REDIS & WORKER
REDIS_URL=redis://redis:6379/0

# SEARCH
SEARXNG_URL=http://searxng:8080
