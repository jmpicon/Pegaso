# PEGASO CORE
APP_ENV=development
SECRET_KEY=4629007f9c8f1e63e9f4a9b5c2a1e8f3  # Example key
ALLOWLIST_PATH=/app/data/vault
LOG_LEVEL=INFO

# LLM (vLLM)
LLM_MODEL=TheBloke/Llama-3-8B-Instruct-AWQ
VLLM_API_BASE=http://vllm:8000/v1
OPENAI_API_KEY=local-pegaso

# DB
POSTGRES_USER=pegaso
POSTGRES_PASSWORD=pegaso_pass
POSTGRES_DB=pegaso_db
DATABASE_URL=postgresql://pegaso:pegaso_pass@db/pegaso_db

# VECTOR DB
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# REDIS & WORKER
REDIS_URL=redis://redis:6379/0

# SEARCH
SEARXNG_URL=http://searxng:8080
