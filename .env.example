# ════════════════════════════════════════════════════════════════
# PEGASO — Configuración completa
# Copia a .env y ajusta los valores
# ════════════════════════════════════════════════════════════════

# ── Core ─────────────────────────────────────────────────────────
APP_ENV=production
SECRET_KEY=cambia-esto-por-una-clave-aleatoria-larga
LOG_LEVEL=INFO
ALLOWLIST_PATH=/app/data/vault

# ── Usuario ──────────────────────────────────────────────────────
# Nombre del usuario para personalización de Pegaso
PEGASO_USER=José

# ── LLM — Ferrumox Fox (corre en el HOST, no en Docker) ──────────
# Fox se lanza con: make fox
# El contenedor API se conecta vía host.docker.internal:11436
#
# Modelos disponibles automáticamente desde LM Studio o ruta custom:
#   DeepSeek R1 Distill 7B (razonamiento, recomendado):
#     /home/jmpicon/.lmstudio/models/lmstudio-community/DeepSeek-R1-Distill-Qwen-7B-GGUF/DeepSeek-R1-Distill-Qwen-7B-Q4_K_M.gguf
#   Llama 3.2 1B (velocidad):
#     /home/jmpicon/.lmstudio/models/hugging-quants/Llama-3.2-1B-Instruct-Q8_0-GGUF/llama-3.2-1b-instruct-q8_0.gguf
#
LLM_MODEL=deepseek-r1-distill-qwen-7b
VLLM_API_BASE=http://host.docker.internal:11436/v1
OPENAI_API_KEY=local-pegaso

# ── Fox — Configuración para el host ──────────────────────────────
FOX_MODEL_PATH=/home/jmpicon/.lmstudio/models/lmstudio-community/DeepSeek-R1-Distill-Qwen-7B-GGUF/DeepSeek-R1-Distill-Qwen-7B-Q4_K_M.gguf
FOX_PORT=11436
FOX_MAX_CONTEXT_LEN=16384
FOX_MAX_BATCH_SIZE=32
FOX_NUM_THREADS=8
FOX_ROPE_SCALING=1.0
FOX_FLASH_ATTN=1
FOX_LOG_LEVEL=info
RUST_LOG=ferrumox=info

# ── Base de datos PostgreSQL ──────────────────────────────────────
POSTGRES_USER=pegaso
POSTGRES_PASSWORD=cambia-esto-en-produccion
POSTGRES_DB=pegaso_db
DATABASE_URL=postgresql://pegaso:cambia-esto-en-produccion@db/pegaso_db

# ── Vector DB Qdrant ──────────────────────────────────────────────
QDRANT_HOST=qdrant
QDRANT_PORT=6333

# ── Redis & Worker ────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Búsqueda privada SearXNG ──────────────────────────────────────
SEARXNG_URL=http://searxng:8080

# ── Aprendizaje adaptativo ────────────────────────────────────────
LEARNING_DIR=/app/data/vault/learning

# ── Opcional: Perplexity CLI (agente externo) ─────────────────────
# PERPLEXITY_API_KEY=tu-api-key-aqui
# PERPLEXITY_MODEL=sonar-pro
